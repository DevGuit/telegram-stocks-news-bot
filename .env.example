# Telegram Bot Configuration
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram chat ID
# To find it: message your bot, then visit https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
TELEGRAM_CHAT_ID=your_chat_id_here

# User Timezone (optional, defaults to Europe/Paris = CEST)
# Use IANA timezone names: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
# Examples: Europe/Paris, America/New_York, Asia/Tokyo, UTC
USER_TIMEZONE=Europe/Paris
